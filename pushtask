#!/usr/bin/env bash
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "$DIR"

echo "========================================="
echo "🚀 ОТПРАВКА ЗАДАЧИ"
echo "========================================="

if [ -z "$1" ]; then
    echo "❌ Укажи путь к задаче!"
    echo "Пример: ./pushtask 01.2.BasicTypes/tasks/hello_world/"
    exit 1
fi

TASK_PATH=$1

echo "📦 Добавляю файлы: $TASK_PATH"
git add $TASK_PATH

echo "📝 Создаю коммит..."
git commit -m "Решение задачи $TASK_PATH"

echo "🚀 Отправляю в GitLab..."
git push origin main

echo "✅ Готово! Проверь пайплайн на gitlab.manytask.org"
